LLM_PROVIDER=ollama
LLM_MODEL=gemma4:e4b
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama

# Alternative: OpenAI
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=

# Alternative: hosted Mistral API
# LLM_PROVIDER=mistral
# LLM_MODEL=mistral-small-latest
# MISTRAL_API_KEY=
# MISTRAL_BASE_URL=https://api.mistral.ai/v1

# Optional Langfuse observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
# Optional: enables a direct trace URL in CLI output.
LANGFUSE_PROJECT_ID=
LANGFUSE_TRACING_ENABLED=true
LANGFUSE_TIMEOUT_SECONDS=5
LANGFUSE_FLUSH_AT=1000
LANGFUSE_FLUSH_INTERVAL_SECONDS=60

# Set to 0 to avoid downloading sentence-transformer/cross-encoder models.
RAG_USE_LOCAL_MODELS=1
# CPU is the safe default. Use cuda only when enough dedicated GPU memory is available.
RAG_DEVICE=cpu
DENSE_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Local Flask interface and HTTP Basic admin login
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=0
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
AGENT_LOG_DB=data/processed/agent_runs.db
